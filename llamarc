# ── llama: model aliases and variables ──────────────────────────────────────
# Sourced from zshrc on snowpeak.
# Edit the per-model blocks below; the generic helpers at the top stay stable.

# ── Helpers ──────────────────────────────────────────────────────────────────

_llama_server() {
  # Usage: _llama_server <hf_path> [--ngl N] [extra flags...]
  local hf_path="$1"; shift
  llama-server -hf "$hf_path" "$@"
}

# ── Build ────────────────────────────────────────────────────────────────────

alias llamamake='cmake --build build --config Release -j --clean-first --target llama-cli llama-mtmd-cli llama-server llama-gguf-split && cp build/bin/llama-* ~/.local/bin'
alias llamaconf='cmake . -B build -DBUILD_SHARED_LIBS=OFF -DGGML_CUDA=ON'

# ── Qwen3.5 (9B) ────────────────────────────────────────────────────────────

QWEN_PATH="unsloth/Qwen3.5-9B-GGUF:UD-Q5_K_XL"
# QWEN_PATH="unsloth/Qwen3.5-27B-GGUF:UD-IQ3_XXS"

QWEN_CODING=(
  --temp 0.6
  --top-p 0.95 --top-k 20
  --min-p 0.0
  --presence-penalty 0.0 --repeat-penalty 1.0
)
QWEN_CHATTING=(
  --temp 1.0
  --top-p 0.95 --top-k 20
  --min-p 0.0
  --presence-penalty 1.5 --repeat-penalty 1.0
)

alias llama-qwen-code='llama-server -hf $QWEN_PATH $QWEN_CODING -np 1'
alias llama-qwen-chat='llama-server -hf $QWEN_PATH $QWEN_CHATTING -np 1'

# ── Claude (via llama) ───────────────────────────────────────────────────────

alias lclaude='
  ANTHROPIC_BASE_URL="http://127.0.0.1:8080"
  ANTHROPIC_AUTH_TOKEN="not-needed"
  ANTHROPIC_API_KEY=""
  claude --model llama
'

# ── Gemma ────────────────────────────────────────────────────────────────────

GEMMA_PATH="unsloth/gemma-4-26B-A4B-it-GGUF:UD-IQ4_XS"

alias llama-gemma='llama-server -hf $GEMMA_PATH -ngl 999 --temp 1.0 --top-p 0.95 --top-k 64 -np 1 --no-mmproj-offload'
